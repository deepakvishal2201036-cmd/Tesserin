{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "main.ts",
        "preload.ts",
        "database.ts",
        "ipc-handlers.ts",
        "ai-service.ts",
        "ppt-generator.ts",
        "mcp-server.ts",
        "knowledge-base.ts",
        "api-server.ts",
        "cloud-agents.ts",
        "mcp-client.ts",
        "mermaid-parser.ts",
        "updater.ts"
    ],
    "exclude": [
        "dist"
    ]
}