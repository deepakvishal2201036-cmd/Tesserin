{
  "$schema": "https://docs.docker.com/ai/mcp-catalog-and-toolkit/schema.json",
  "name": "tesserin",
  "description": "Tesserin Knowledge Workspace — exposes vault notes, knowledge graph, tasks, and AI capabilities as MCP tools for external agents.",
  "profiles": {
    "default": {
      "servers": {
        "tesserin": {
          "type": "local",
          "command": "node",
          "args": ["tesserin-mcp/dist/index.js"],
          "env": {
            "TESSERIN_API_TOKEN": "${TESSERIN_API_TOKEN}",
            "TESSERIN_API_URL": "${TESSERIN_API_URL:-http://127.0.0.1:9960}"
          },
          "description": "Tesserin vault MCP server — full access to notes, tags, tasks, folders, knowledge graph, canvas, and AI tools. Standalone Node.js — no Docker or Electron build required.",
          "tools": [
            "list_notes",
            "get_note",
            "get_note_by_title",
            "search_notes",
            "create_note",
            "update_note",
            "delete_note",
            "append_to_note",
            "pin_note",
            "archive_note",
            "get_recent_notes",
            "batch_create_notes",
            "list_tags",
            "create_tag",
            "delete_tag",
            "add_tag_to_note",
            "list_tasks",
            "create_task",
            "update_task",
            "delete_task",
            "list_folders",
            "create_folder",
            "delete_folder",
            "get_knowledge_graph",
            "search_vault_context",
            "get_vault_context",
            "export_vault",
            "get_note_with_connections",
            "get_vault_summary",
            "create_diagram",
            "list_canvases",
            "get_canvas",
            "create_canvas",
            "update_canvas_name",
            "delete_canvas",
            "add_canvas_elements",
            "ai_chat",
            "ai_summarize",
            "ai_generate_tags",
            "ai_suggest_links",
            "list_templates",
            "check_health"
          ]
        }
      }
    },
    "readonly": {
      "servers": {
        "tesserin": {
          "type": "local",
          "command": "node",
          "args": ["tesserin-mcp/dist/index.js"],
          "env": {
            "TESSERIN_API_TOKEN": "${TESSERIN_API_TOKEN}",
            "TESSERIN_API_URL": "${TESSERIN_API_URL:-http://127.0.0.1:9960}"
          },
          "description": "Tesserin vault read-only access — browse notes, search, and access knowledge graph.",
          "tools": [
            "list_notes",
            "get_note",
            "get_note_by_title",
            "search_notes",
            "get_recent_notes",
            "list_tags",
            "list_tasks",
            "list_folders",
            "get_knowledge_graph",
            "search_vault_context",
            "get_vault_context",
            "export_vault",
            "get_note_with_connections",
            "get_vault_summary",
            "list_canvases",
            "get_canvas",
            "list_templates",
            "check_health"
          ]
        }
      }
    },
    "http": {
      "servers": {
        "tesserin": {
          "type": "remote",
          "url": "http://localhost:3200",
          "description": "Tesserin vault via HTTP/SSE transport — for browser-based agents that cannot spawn subprocesses.",
          "env": {
            "TESSERIN_API_TOKEN": "${TESSERIN_API_TOKEN}"
          }
        }
      }
    }
  }
}
